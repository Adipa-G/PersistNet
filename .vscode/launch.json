            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Run Tests in Current File",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "run-tests-current-file",
            "program": "${workspaceFolder}/tests/PersistNet.Tests/bin/Debug/net8.0/PersistNet.Tests.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
